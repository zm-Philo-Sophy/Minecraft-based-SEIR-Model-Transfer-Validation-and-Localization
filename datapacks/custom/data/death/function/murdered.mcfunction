#set killed_by_player score to zero
scoreboard players set @s killed_by_player 0
#when activated by dead villager, place a sign orientated depending on city
execute as @e[type=armor_stand,tag=gravedigger,limit=1,sort=nearest,distance=..80] at @s if entity @s[tag=dundee] run setblock ~ ~ ~ crimson_sign[rotation=0]{front_text:{messages:[[{"text":"R.I.P.","color":"gold"}],[{"text":"Villager","color":"gold"}],[{"text":"MURDERED BY","color":"gold"}],[{"text":"Health Team","color":"gold"}]]}} keep 
execute as @e[type=armor_stand,tag=gravedigger,limit=1,sort=nearest,distance=..80] at @s if entity @s[tag=edinburgh] run setblock ~ ~ ~ crimson_sign[rotation=12]{front_text:{messages:[[{"text":"R.I.P.","color":"gold"}],[{"text":"Villager","color":"gold"}],[{"text":"MURDERED BY","color":"gold"}],[{"text":"Health Team","color":"gold"}]]}} keep 
